import.version:3.0.0 {unitt}! 
import {src/relative-distance}!

describe "Relative Distance" [
    it "Direct parent-child relation" [
        familyTree: #[
            Vera: ["Tomoko"]
            Tomoko: ["Aditi"]
        ]
        result: degreeOfSeparation familyTree "Vera" "Tomoko"
        expects.be:'equal? @[1 result]
    ]

    it.skip "Sibling relationship" [
        familyTree: #[
            Dalia: ["Olga" "Yassin"]
        ]
        result: degreeOfSeparation familyTree "Olga" "Yassin"
        expects.be:'equal? @[1 result]
    ]

    it.skip "Two degrees of separation, grandchild" [
        familyTree: #[
            Khadija: ["Mateo"]
            Mateo: ["Rami"]
        ]
        result: degreeOfSeparation familyTree "Khadija" "Rami"
        expects.be:'equal? @[2 result]
    ]

    it.skip "Unrelated individuals" [
        familyTree: #[
            Priya: ["Rami"]
            Kaito: ["Elif"]
        ]
        result: degreeOfSeparation familyTree "Priya" "Kaito"
        expects.be:'equal? @[null result]
    ]

    it.skip "Complex graph, cousins" [
        familyTree: #[
            Aiko: ["Bao" "Carlos"]
            Bao: ["Dalia" "Elias"]
