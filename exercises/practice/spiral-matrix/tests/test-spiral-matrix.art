import.version:3.0.0 {unitt}! 
import {src/spiral-matrix}!

describe "Spiral Matrix" [
    it "empty spiral" [
        expects.be:'equal? @[[] spiralMatrix 0]
    ]

    it.skip "trivial spiral" [
        expected: [
            [1]
        ]
        expects.be:'equal? @[expected spiralMatrix 1]
    ]

    it.skip "spiral of size 2" [
        expected: [
            [1 2]
            [4 3]
        ]
        expects.be:'equal? @[expected spiralMatrix 2]
    ]

    it.skip "spiral of size 3" [
        expected: [
            [1 2 3]
            [8 9 4]
            [7 6 5]
        ]
        expects.be:'equal? @[expected spiralMatrix 3]
    ]

    it.skip "spiral of size 4" [
        expected: [
            [1 2 3 4]
            [12 13 14 5]
            [11 16 15 6]
            [10 9 8 7]
        ]
        expects.be:'equal? @[expected spiralMatrix 4]
    ]

    it.skip "spiral of size 5" [
        expected: [
            [1 2 3 4 5]
            [16 17 18 19 6]
            [15 24 25 20 7]
            [14 23 22 21 8]
            [13 12 11 10 9]
        ]
        expects.be:'equal? @[expected spiralMatrix 5]
    ]
]
